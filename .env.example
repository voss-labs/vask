# vask deploy secrets — copy to .env and fill in.
# .env is gitignored. Never put real values in this template.
#
# usage:
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
#   ./deploy/setup-oracle.sh
#
# Picked up by the deploy script AND by the running binary
# (via systemd EnvironmentFile=/opt/vask/data/turso.env).

# Turso (production database)
# Created at app.turso.tech. URL looks like:
#   libsql://vask-<you>.<region>.turso.io
# Token: turso db tokens create vask-<you> --expiration none
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Cloudflare Workers AI (optional — enables semantic search,
# compose tag suggestions, and AI-assisted post drafting).
# Leave blank to disable: app still runs, search falls back to LIKE.
#
# Account ID: dashboard → Workers & Pages → Overview → right sidebar.
# Token:      dashboard → My Profile → API Tokens → "Workers AI" template.
CF_ACCOUNT_ID=
CF_AI_TOKEN=
